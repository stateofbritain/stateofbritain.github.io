  "pgms-dependency":        { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk HS 7110 (Pt/Pd/Rh) by COO" },
  "petroleum-dependency":   { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk HS 2710.12+19 by COO; fetch 18th" },
  "crude-oil-dependency":   { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk HS 2709 by COO" },
  "aluminium-dependency":   { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk HS 76 by COO" },
  "copper-dependency":      { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk HS 74 by COO" },
  "polymers-dependency":    { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk HS 39 by COO" },
  "fertilisers-dependency": { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk HS 31 by COO" },
  "tropical-dependency":    { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk HS 09+18 (coffee/tea/cocoa) by COO" },
  "dependency-rollup":      { "type": "fixed-dom", "dom": 19, "release": "Rollup of all *-dependency.json files; idempotent, runs after the commodity fetches on day 18" },
  "iop-pharma":             { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "ONS Index of Production pharma (GDP day) + 1d" },
  "unga-alignment":         { "type": "fixed-dom", "dom": 15, "release": "Voeten UNGA dataset updates ~annually; refresh 15th monthly (cheap with cache)" },
  "mfg-output":             { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "ONS Manufacturing (GDP day) + 1d" },
  "construction-output":    { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "ONS Construction (GDP day) + 1d" },
  "services-output":        { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "ONS Services (GDP day) + 1d" },

  "borrowing":              { "type": "nth-weekday", "n": 4, "weekday": 3, "offsetDays": 1, "release": "ONS Public Sector Finances ~4th Wed + 1d" },
  "public-sector-debt":     { "type": "nth-weekday", "n": 4, "weekday": 3, "offsetDays": 1, "release": "ONS Public Sector Finances ~4th Wed + 1d" },

  "retail-sales":           { "type": "nth-weekday", "n": 4, "weekday": 5, "offsetDays": 3, "release": "ONS Retail ~4th Fri + 3d (skip weekend)" },

  "nhs":                    { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "NHS England 2nd Thu 09:30 UK + 1d (RTT/A&E/cancer)" },
  "gp-access":              { "type": "last-weekday", "weekday": 4, "offsetDays": 1, "release": "NHS Digital last Thu + 1d (GP appointments)" },

  "heat-pumps-bus":         { "type": "last-weekday", "weekday": 4, "offsetDays": 1, "release": "DESNZ BUS last Thu 09:30 UK + 1d" },
  "energy":                 { "type": "last-weekday", "weekday": 4, "offsetDays": 1, "release": "DESNZ Energy Trends last Thu + 1d" },
  "gas-imports":            { "type": "fixed-dom", "dom": 18, "release": "HMRC bulk-COO HS 2711.11+21 — same window as gas-dependency" },

  "asylum-statistics":      { "type": "last-weekday", "weekday": 4, "offsetDays": 1, "months": [2,5,8,11], "release": "Home Office quarterly last Thu Feb/May/Aug/Nov + 1d" },
  "immigration":            { "type": "last-weekday", "weekday": 4, "offsetDays": 1, "months": [2,5,8,11], "release": "Home Office quarterly + 1d" },

  "knife-crime-quarterly":  { "type": "last-weekday", "weekday": 4, "offsetDays": 1, "months": [1,4,7,10], "release": "ONS Crime in E&W quarterly last Thu Jan/Apr/Jul/Oct + 1d" },

  "court-backlog-quarterly":{ "type": "last-weekday", "weekday": 4, "offsetDays": 1, "months": [3,6,9,12], "release": "MoJ Criminal Courts quarterly last Thu Mar/Jun/Sep/Dec + 1d" },

  "births-quarterly":       { "type": "last-weekday", "weekday": 4, "offsetDays": 1, "months": [2,5,8,11], "release": "ONS Quarterly Births Feb/May/Aug/Nov + 1d" },

  "ofgem-price-cap":        { "type": "fixed-dom", "dom": 28, "months": [2,5,8,11], "release": "Ofgem cap announcement ~26th of Feb/May/Aug/Nov; fetch 28th" },

  "money-supply":           { "type": "fixed-dom", "dom": 2, "release": "BoE Money & Credit ~21st-working-day; fetch 2nd of next month" },

  "exchange-rates":         { "type": "daily", "release": "BoE daily fixing" },

  "school-absence":         { "type": "weekly", "weekday": 5, "release": "DfE EES Pupil attendance — Thu morning + 1d (Fri)" },
  "births-monthly":         { "type": "last-weekday", "weekday": 4, "offsetDays": 1, "release": "NHS Digital MSDS last Thu + 1d" },
  "train-ppm":              { "type": "fixed-dom", "dom": 26, "release": "ORR Passenger rail performance ~last Wed of period" },
  "epc-newbuild":           { "type": "fixed-dom", "dom": 5, "release": "EPC Open Data continuous; aggregate 5th of month" },

