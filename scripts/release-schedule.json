{
  "_comment": "Maps each fetch script to its upstream-release pattern. The dispatcher (run-scheduled-fetches.js) runs daily and triggers every fetch whose rule matches today. Patterns target the day AFTER expected release for buffer. Weekday: 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat. Months: 1-12.",
  "_legend": {
    "daily": "run every day",
    "weekly": "run every week on weekday N",
    "nth-weekday": "n-th weekday of month, optionally + offsetDays",
    "last-weekday": "last weekday of month, optionally + offsetDays",
    "fixed-dom": "fixed day-of-month",
    "months": "optional 1-12 array — only run in these months (for quarterly)"
  },

  "co2-intensity":          { "type": "daily", "release": "NESO real-time API" },
  "tech-incorporations":    { "type": "daily", "release": "Companies House daily API" },
  "battery-storage-neso":   { "type": "daily", "release": "NESO Data Portal (irregular; poll daily)" },

  "cpih":                   { "type": "nth-weekday", "n": 3, "weekday": 3, "offsetDays": 1, "release": "ONS CPI 3rd Wed 07:00 UK + 1d" },
  "cpi-inflation":          { "type": "nth-weekday", "n": 3, "weekday": 3, "offsetDays": 1, "release": "ONS CPI 3rd Wed 07:00 UK + 1d" },
  "house-price-index":      { "type": "nth-weekday", "n": 3, "weekday": 3, "offsetDays": 1, "release": "ONS HPI mid-month + 1d" },

  "real-wages-monthly":     { "type": "nth-weekday", "n": 3, "weekday": 2, "offsetDays": 1, "release": "ONS Labour Market 3rd Tue 07:00 UK + 1d" },
  "employment-rate":        { "type": "nth-weekday", "n": 3, "weekday": 2, "offsetDays": 1, "release": "ONS Labour Market 3rd Tue + 1d" },
  "unemployment-rate":      { "type": "nth-weekday", "n": 3, "weekday": 2, "offsetDays": 1, "release": "ONS Labour Market 3rd Tue + 1d" },
  "economic-inactivity":    { "type": "nth-weekday", "n": 3, "weekday": 2, "offsetDays": 1, "release": "ONS Labour Market 3rd Tue + 1d" },
  "avg-weekly-hours":       { "type": "nth-weekday", "n": 3, "weekday": 2, "offsetDays": 1, "release": "ONS Labour Market 3rd Tue + 1d" },
  "jobs":                   { "type": "nth-weekday", "n": 3, "weekday": 2, "offsetDays": 1, "release": "ONS Labour Market 3rd Tue + 1d" },

  "monthly-gdp":            { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "ONS GDP 2nd Thu 07:00 UK + 1d" },
  "iop-chemicals":          { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "ONS Index of Production (GDP day) + 1d" },
  "iop-cement":             { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "ONS Index of Production cement (GDP day) + 1d" },
  "iop-steel":              { "type": "nth-weekday", "n": 2, "weekday": 4, "offsetDays": 1, "release": "ONS Index of Production iron & steel (GDP day) + 1d" },
  "steel-trade":            { "type": "fixed-dom", "dom": 15, "release": "HMRC OTS publishes ~13th of each month for M-2; fetch 15th" },
  "steel-consumption":      { "type": "daily", "release": "Derived from steel-trade.json + iop-steel.json; cheap, idempotent" },
  "steel-dependency":       { "type": "fixed-dom", "dom": 16, "release": "HMRC OTS by partner country (~80s run); fetch 16th after steel-trade" },
  "pharma-dependency":      { "type": "fixed-dom", "dom": 16, "release": "HMRC OTS HS 30 by partner country; same window as steel-dependency" },
  "gas-dependency":         { "type": "fixed-dom", "dom": 16, "release": "HMRC OTS HS 2711.11+21 (LNG + pipeline gas) by partner country" },
  "semiconductor-dependency": { "type": "fixed-dom", "dom": 16, "release": "HMRC OTS HS 8541-8542 (semiconductors) by partner country" },
  "food-dependency":        { "type": "fixed-dom", "dom": 17, "release": "HMRC OTS food chapters (02/04/07/08/10) — 5 facets × 24 mo, ~6min run" },
