    "sesroTimeline": {
      "sourceId": "ukceh-reservoirs",
      "timeField": "year",
      "description": "Key milestones in the SESRO (Abingdon Reservoir) project, from first proposal in 2006 to projected completion in 2040",
      "data": [
        {
          "year": 2006,
          "event": "Thames Water identifies Upper Thames Reservoir in draft WRMP",
          "phase": "planning"
        },
        {
          "year": 2010,
          "event": "Public inquiry into Thames Water's WRMP including reservoir proposal",
          "phase": "planning"
        },
        {
          "year": 2011,
          "event": "Secretary of State rejects the Abingdon reservoir after Planning Inspector recommends against",
          "phase": "rejected"
        },
        {
          "year": 2017,
          "event": "National Infrastructure Commission recommends new strategic water resources for the South East",
          "phase": "revival"
        },
        {
          "year": 2020,
          "event": "RAPID (Regulators' Alliance) formed; SESRO enters gated assessment process",
          "phase": "revival"
        },
        {
          "year": 2022,
          "event": "SESRO passes RAPID Gate 2 assessment",
          "phase": "revival"
        },
        {
          "year": 2023,
          "event": "Thames Water includes SESRO in revised WRMP; scheme formally revived",
          "phase": "revival"
        },
        {
          "year": 2025,
